---

import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | Arnian Moving">
  <div class="min-h-[70vh] flex flex-col items-center justify-center px-4 py-16 md:py-24">
    <div class="text-center max-w-xl mx-auto">
      <!-- Número de error grande -->
      <div class="text-8xl md:text-9xl font-bold text-brand-primary mb-6">404</div>
      
      <!-- Mensaje principal -->
      <h1 class="text-3xl md:text-4xl font-bold text-brand-primary mb-4">¡Oops! Página no encontrada</h1>
      
      <!-- Mensaje secundario -->
      <p class="text-lg text-brand-gray mb-8">
        Lo sentimos, la página que estás buscando no existe o ha sido movida.
      </p>
      
      <!-- Botón de regreso -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="bg-brand-accent hover:bg-brand-accent/90 text-white font-medium py-3 px-6 rounded-md shadow-md hover:shadow-lg transition-all inline-flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Volver al inicio
        </a>
        
        <a href="/contact" class="border border-brand-border bg-white hover:bg-gray-50 text-brand-primary font-medium py-3 px-6 rounded-md shadow-sm hover:shadow-md transition-all inline-flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          Contactarnos
        </a>
      </div>
    </div>
  </div>
</Layout>